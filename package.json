{
  "name": "hono-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "serve": "bun src/server.ts",
    "build": "bun build ./src/server.ts --outdir ./dist --target=bun --external sharp",
    "start": "bun ./dist/server.js",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "auth:generate": "bunx auth@latest generate --config src/modules/auth/auth.service.ts --output src/db/schema/auth.ts --yes",
    "db:generate": "bun --env-file=.env.local x drizzle-kit generate",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts",
    "db:push": "bun --env-file=.env.local x drizzle-kit push",
    "db:studio": "bun --env-file=.env.local x drizzle-kit studio"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@arcjet/bun": "^1.6.1",
    "@better-auth/drizzle-adapter": "^1.4.0",
    "@hono/standard-validator": "^0.2.3",
    "@scalar/hono-api-reference": "^0.10.12",
    "better-auth": "^1.4.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.12.16",
    "hono-openapi": "^1.3.0",
    "pg": "^8.16.0",
    "pino": "^10.3.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^6.0.3"
  }
}
